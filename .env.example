# Copie este arquivo para .env (localmente) e configure a mesma variável
# nas Environment Variables do projeto na Vercel.
#
# String de conexão do banco Postgres. Se estiver usando o Vercel Postgres
# (Storage > Create Database > Postgres, powered by Neon), a Vercel já
# preenche isso automaticamente ao conectar o projeto ao banco.
DATABASE_URL="postgresql://usuario:senha@host:5432/nome_do_banco?sslmode=require"
